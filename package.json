{
  "dependencies": {
    "dayjs": "^1.11.20",
    "md5": "^2.3.0"
  },
  "devDependencies": {
    "@types/md5": "^2.3.6",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4"
  },
  "scripts": {
    "web:dev": "pnpm --filter @fe26/web dev",
    "server:dev": "pnpm --filter @fe26/server dev",
    "dev": "concurrently \"pnpm web:dev\" \"pnpm server:dev\"",
    "web:format": "pnpm --filter @fe26/web format",
    "server:format": "pnpm --filter @fe26/server format",
    "format": "concurrently \"pnpm web:format\" \"pnpm server:format\"",
    "git:commit": "git add -A && git commit -m \"feat: Introduce new features\"",
    "git:push": "pnpm git:commit && git push origin main"
  }
}
