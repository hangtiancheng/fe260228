{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "exactOptionalPropertyTypes": false,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "rootDir": "./",
    "outDir": "./dist"
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "eslint.config.mjs",
    "prisma.config.ts"
  ],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}
