# Server
NODE_ENV="development"
PORT=3000
LOG_LEVEL="info"

# PostgreSQL
DATABASE_URL="postgresql://root:pass@127.0.0.1:5432/ai_en"

# Authentication
JWT_SECRET="012345abcdefghijklmnopqrstuvwxyz"

# MinIO
MINIO_ACCESS_KEY="<your-minio-access-key>"
MINIO_SECRET_KEY="<your-minio-secret-key>"
MINIO_ENDPOINT="127.0.0.1"
MINIO_PORT=9000
MINIO_USE_SSL=0
MINIO_BUCKET="bucket"

# AI
AI_PROVIDER="deepseek" # ollama or deepseek

DEEPSEEK_API_KEY=""
DEEPSEEK_API_MODEL="deepseek-chat"
DEEPSEEK_REASONER_API_MODEL="deepseek-reasoner"

OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen3.5"
OLLAMA_REASONER_MODEL="deepseek-r1"

BOCHA_ENABLED=false
BOCHA_SEARCH_URL=""
BOCHA_API_KEY=""

# Redis
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Email
EMAIL_ENABLED=false
EMAIL_HOST=""
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_USER=""
EMAIL_PASSWORD=""
EMAIL_FROM=""

# Payment boundary
ALIPAY_ENABLED=true
ALIPAY_APP_ID="<your-alipay-app-id>"
ALIPAY_PRIVATE_KEY="<your-alipay-private-key>"
ALIPAY_PUBLIC_KEY="<your-alipay-public-key>"
ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"
ALIPAY_NOTIFY_URL="https://api.example.com"
PAYMENT_NOTIFY_SECRET=""

# Staging smoke
STAGING_BASE_URL="https://staging.example.com"
STAGING_SMOKE_TIMEOUT_MS=5000
