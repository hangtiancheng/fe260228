# Server
NODE_ENV="development"
PORT=3000
LOG_LEVEL="info"

# PostgreSQL
DATABASE_URL="postgresql://root:pass@127.0.0.1:5432/fe26"

# Authentication
JWT_SECRET="012345abcdefghijklmnopqrstuvwxyz"

# MinIO
