{
  "name": "@fe26/server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest run --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings 0",
    "format": "biome format --write",
    "check": "biome check --write",
    "ci": "pnpm build && pnpm test && pnpm lint:ci && pnpm prisma:validate",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "word-book:import": "tsx prisma/import-word-book.ts",
    "staging:smoke": "tsx src/operations/run-staging-smoke.ts"
  },
  "dependencies": {
    "@fe26/common": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "@langchain/core": "^1.1.46",
    "@langchain/deepseek": "^1.0.25",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/ollama": "^1.2.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node-cron": "^3.0.11",
    "alipay-sdk": "^4.14.0",
    "bullmq": "^5.76.10",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "generic-pool": "^3.9.0",
    "hono": "^4.12.19",
    "hono-pino": "^0.10.3",
    "iconv-lite": "^0.7.2",
    "ioredis": "^5.10.1",
    "langchain": "^1.4.0",
    "marked": "^17.0.6",
    "minio": "^8.0.7",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "globals": "^16.5.0",
    "msw": "^2.14.6",
    "prisma": "^7.8.0",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
